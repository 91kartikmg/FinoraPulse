<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pro Calculators | FinoraPulse</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@500;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/home.css" crossorigin="anonymous">
    
    <style>
        /* Existing FinoraPulse Core Styles */
        :root {
            --card-bg: #1e293b;
            --border: #334155;
            --accent: #38bdf8;
            --bg-dark: #041027;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --profit: #00FF9D;
            --loss: #FF007F;
        }

        .macro-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        
        /* Sidebar Navigation Styles */
        .tool-nav { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
        .tool-nav li {
            padding: 12px 18px; background: rgba(15, 23, 42, 0.4); border: 1px solid transparent;
            border-radius: 8px; color: var(--text-muted); cursor: pointer; font-weight: 600; transition: all 0.2s;
        }
        .tool-nav li:hover { background: rgba(56, 189, 248, 0.1); color: var(--text-main); }
        .tool-nav li.active {
            background: rgba(56, 189, 248, 0.15); border-color: var(--accent); color: var(--accent);
            border-left: 4px solid var(--accent);
        }

        /* Calculator UI Styles */
        .calc-section { display: none; animation: fadeIn 0.3s ease-in-out; }
        .calc-section.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .stat-card {
            background: var(--card-bg); padding: 30px; border-radius: 16px;
            border: 1px solid var(--border); box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        .input-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; margin-bottom: 30px; }
        .input-group { display: flex; flex-direction: column; gap: 10px; }
        .input-group label { color: var(--text-muted); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
        
        .slider-wrapper { display: flex; align-items: center; gap: 15px; }
        
        .input-group input[type="number"] {
            background: #0f172a; border: 1px solid var(--border); color: white;
            padding: 10px 12px; border-radius: 8px; font-family: 'JetBrains Mono', monospace; font-size: 1rem; outline: none; transition: border-color 0.2s;
            width: 110px; text-align: right;
        }
        .input-group input[type="number"]:focus { border-color: var(--accent); box-shadow: 0 0 10px rgba(56, 189, 248, 0.2); }

        /* Custom Range Slider (Line Adjustment) CSS */
        input[type=range] {
            -webkit-appearance: none; width: 100%; background: transparent; flex-grow: 1;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none; height: 20px; width: 20px; border-radius: 50%;
            background: var(--accent); cursor: pointer; margin-top: -7px;
            box-shadow: 0 0 10px rgba(56, 189, 248, 0.6); transition: transform 0.1s;
        }
        input[type=range]::-webkit-slider-thumb:hover { transform: scale(1.2); }
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%; height: 6px; cursor: pointer; background: var(--border); border-radius: 3px;
        }
        input[type=range]:focus { outline: none; }
        input[type=range]:focus::-webkit-slider-runnable-track { background: #475569; }

        /* Results Display */
        .result-panel {
            background: #0d1117; border: 1px solid var(--border); border-radius: 12px; padding: 25px;
            display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;
        }
        .result-item { display: flex; flex-direction: column; gap: 5px; }
        .result-label { font-size: 0.8rem; color: #a855f7; text-transform: uppercase; font-weight: bold; }
        .result-value { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 900; color: #fff; }
        
        .val-profit { color: var(--profit); }
        .val-loss { color: var(--loss); }

        /* SIP Chart Container */
        .chart-container { height: 250px; width: 250px; margin: 0 auto; }

        /* ✨ MOBILE RESPONSIVE & HAMBURGER MENU CSS ✨ */
        @media screen and (max-width: 768px) {
            .main-wrapper { padding: 0 !important; }
            .content-panel { padding: 15px !important; border-radius: 0 !important; border-left: none; border-right: none; }
            
            /* Full width cards on mobile */
            .stat-card {
                margin-left: -15px; margin-right: -15px; border-radius: 0 !important; 
                border-left: none !important; border-right: none !important;
            }

            .slider-wrapper { flex-wrap: wrap; gap: 10px; }
            .input-group input[type="number"] { width: 100%; text-align: left; }

            /* Hamburger Mobile Sidebar Setup */
            .ticker-sidebar { display: none; }
            .ticker-sidebar.open {
                display: block; position: fixed; top: 0; left: 0;
                width: 80%; max-width: 300px; height: 100vh; z-index: 2000;
                background: #0f172a; border-right: 1px solid var(--accent);
                box-shadow: 10px 0 50px rgba(0, 0, 0, 0.9); overflow-y: auto;
            }
        }
    </style>
</head>
<body>

    <%- include('partials/header') %>

    <div class="main-wrapper">
        <aside class="ticker-sidebar" style="padding: 20px;">
            <div style="font-size: 0.8rem; color: #a855f7; text-transform: uppercase; font-weight: bold; margin-bottom: 15px; padding-left: 5px;">Toolkit</div>
            <ul class="tool-nav">
                <li class="active" onclick="switchTool('sip', this)">SIP Calculator</li>
                <li onclick="switchTool('pnl', this)">Profit & Loss</li>
                <li onclick="switchTool('position', this)">Position Sizer</li>
                <li onclick="switchTool('cagr', this)">CAGR Calculator</li>
            </ul>
        </aside>

        <main class="content-panel">
            <div class="macro-header">
                <div>
                    <h1 style="margin:0; font-size: 2.2rem;">Pro <span class="accent">Calculators</span></h1>
                    <p style="color:var(--text-muted); margin-top:5px;">Real-time, browser-side algorithmic tools.</p>
                </div>
            </div>

            <div id="tool-sip" class="calc-section active stat-card">
                <h2 style="margin-top:0; color:var(--text-main);">Systematic Investment Plan (SIP)</h2>
                <div style="display: flex; flex-wrap: wrap; gap: 40px; align-items: center;">
                    <div style="flex: 1; min-width: 300px;">
                        <div class="input-grid" style="grid-template-columns: 1fr;">
                            <div class="input-group">
                                <label>Monthly Investment (₹)</label>
                                <div class="slider-wrapper">
                                    <input type="range" id="sip-amount-slider" min="100" max="500000" step="500" value="5000">
                                    <input type="number" id="sip-amount" min="100" max="500000" value="5000">
                                </div>
                            </div>
                            <div class="input-group">
                                <label>Expected Return Rate (p.a %)</label>
                                <div class="slider-wrapper">
                                    <input type="range" id="sip-rate-slider" min="0" max="100" step="0.5" value="12">
                                    <input type="number" id="sip-rate" min="0" max="100" value="12">
                                </div>
                            </div>
                            <div class="input-group">
                                <label>Time Period (Years)</label>
                                <div class="slider-wrapper">
                                    <input type="range" id="sip-years-slider" min="0" max="50" step="1" value="10">
                                    <input type="number" id="sip-years" min="0" max="50" value="10">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas id="sipChart"></canvas>
                    </div>
                </div>

                <div class="result-panel" style="margin-top: 20px;">
                    <div class="result-item">
                        <span class="result-label">Total Invested</span>
                        <span class="result-value" id="sip-invested">₹6,00,000</span>   
                    </div>
                    <div class="result-item">
                        <span class="result-label" style="color:var(--accent);">Est. Returns</span>
                        <span class="result-value" id="sip-returns" style="color:var(--accent);">₹5,61,695</span>
                    </div>
                    <div class="result-item" style="text-align: right;">
                        <span class="result-label" style="color:var(--profit);">Total Wealth</span>
                        <span class="result-value val-profit" id="sip-total">₹11,61,695</span>
                    </div>
                </div>
            </div>

            <div id="tool-pnl" class="calc-section stat-card">
                <h2 style="margin-top:0; color:var(--text-main);">Trade Profit & Loss</h2>
                <div class="input-grid">
                    <div class="input-group">
                        <label>Buy Price</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pnl-buy-slider" min="1" max="500000" step="1" value="150">
                            <input type="number" id="pnl-buy" min="1" max="500000" value="150">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Sell Price</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pnl-sell-slider" min="1" max="500000" step="1" value="165">
                            <input type="number" id="pnl-sell" min="1" max="500000" value="165">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Quantity</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pnl-qty-slider" min="1" max="10000" step="1" value="100">
                            <input type="number" id="pnl-qty" min="1" max="10000" value="100">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Total Brokerage/Fees</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pnl-fees-slider" min="0" max="50000" step="10" value="20">
                            <input type="number" id="pnl-fees" min="0" max="50000" value="20">
                        </div>
                    </div>
                </div>

                <div class="result-panel">
                    <div class="result-item">
                        <span class="result-label">Total Capital Required</span>
                        <span class="result-value" id="pnl-capital" style="font-size: 1.5rem;">₹15,020</span>
                    </div>
                    <div class="result-item" style="text-align: right;">
                        <span class="result-label" id="pnl-status-label">Net Profit</span>
                        <span class="result-value val-profit" id="pnl-net">₹1,480.00 <span style="font-size: 1rem;">(9.85%)</span></span>
                    </div>
                </div>
            </div>

            <div id="tool-position" class="calc-section stat-card">
                <h2 style="margin-top:0; color:var(--text-main);">Risk Manager / Position Sizer</h2>
                <p style="color:var(--text-muted); font-size:0.9rem;">Calculate exact share quantity to prevent blowing up your account.</p>
                <div class="input-grid">
                    <div class="input-group">
                        <label>Total Account Capital</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pos-capital-slider" min="100" max="500000" step="1000" value="100000">
                            <input type="number" id="pos-capital" min="100" max="500000" value="100000">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Risk % per Trade</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pos-risk-slider" min="0.1" max="100" step="0.1" value="2">
                            <input type="number" id="pos-risk" min="0.1" max="100" value="2">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Entry Price</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pos-entry-slider" min="1" max="500000" step="1" value="500">
                            <input type="number" id="pos-entry" min="1" max="500000" value="500">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Stop Loss Price</label>
                        <div class="slider-wrapper">
                            <input type="range" id="pos-stop-slider" min="1" max="500000" step="1" value="480">
                            <input type="number" id="pos-stop" min="1" max="500000" value="480">
                        </div>
                    </div>
                </div>

                <div class="result-panel" style="border-left: 4px solid var(--accent);">
                    <div class="result-item">
                        <span class="result-label">Amount at Risk</span>
                        <span class="result-value" id="pos-risk-amount" style="font-size: 1.5rem; color:var(--loss);">₹2,000</span>
                    </div>
                    <div class="result-item" style="text-align: right;">
                        <span class="result-label" style="color:var(--accent);">Max Position Size (Qty)</span>
                        <span class="result-value" id="pos-qty">100</span>
                    </div>
                </div>
            </div>

            <div id="tool-cagr" class="calc-section stat-card">
                <h2 style="margin-top:0; color:var(--text-main);">Compound Annual Growth Rate (CAGR)</h2>
                <div class="input-grid">
                    <div class="input-group">
                        <label>Initial Investment Value</label>
                        <div class="slider-wrapper">
                            <input type="range" id="cagr-initial-slider" min="100" max="500000" step="1000" value="10000">
                            <input type="number" id="cagr-initial" min="100" max="500000" value="10000">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Final Investment Value</label>
                        <div class="slider-wrapper">
                            <input type="range" id="cagr-final-slider" min="100" max="1000000" step="1000" value="25000">
                            <input type="number" id="cagr-final" min="100" max="1000000" value="25000">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Duration (Years)</label>
                        <div class="slider-wrapper">
                            <input type="range" id="cagr-years-slider" min="0" max="50" step="0.5" value="5">
                            <input type="number" id="cagr-years" min="0" max="50" value="5">
                        </div>
                    </div>
                </div>

                <div class="result-panel">
                    <div class="result-item">
                        <span class="result-label">Absolute Return</span>
                        <span class="result-value" id="cagr-absolute" style="font-size: 1.5rem;">150.00%</span>
                    </div>
                    <div class="result-item" style="text-align: right;">
                        <span class="result-label" style="color:var(--profit);">CAGR</span>
                        <span class="result-value val-profit" id="cagr-result">20.11%</span>
                    </div>
                </div>
            </div>

            <div style="height: 40px;"></div>
        </main>

        <aside class="side-panel right">
            <div class="sidebar-header" style="padding: 0 0 15px 0; border-bottom: none;">Sponsors</div>
            <div class="ad-placeholder" style="background: rgba(0,0,0,0.2);"><span>Ad Slot</span><span style="font-size: 0.65rem; margin-top: 5px;">300 x 250</span></div>
        </aside>
    </div>

    <script>
        // --- 0. HAMBURGER MENU LOGIC ---
        document.addEventListener('DOMContentLoaded', () => {
            const menuBtn = document.querySelector('.hamburger-btn') || document.getElementById('mobile-menu-btn');
            const sidebar = document.querySelector('.ticker-sidebar');
            
            if(menuBtn && sidebar) {
                menuBtn.addEventListener('click', (e) => {
                    e.stopPropagation(); 
                    sidebar.classList.toggle('open');
                });

                document.addEventListener('click', (e) => {
                    if (sidebar.classList.contains('open') && !sidebar.contains(e.target) && e.target !== menuBtn) {
                        sidebar.classList.remove('open');
                    }
                });
            }
        });

        // --- 1. UI NAVIGATION LOGIC ---
        function switchTool(toolId, listElement) {
            document.querySelectorAll('.tool-nav li').forEach(el => el.classList.remove('active'));
            listElement.classList.add('active');
            document.querySelectorAll('.calc-section').forEach(el => el.classList.remove('active'));
            document.getElementById('tool-' + toolId).classList.add('active');

            const sidebar = document.querySelector('.ticker-sidebar');
            if (sidebar) sidebar.classList.remove('open');
        }

        const fmt = (num) => new Intl.NumberFormat('en-IN', { maximumFractionDigits: 2 }).format(num);

        // --- SLIDER SYNC LOGIC ---
        // Keeps the visual range slider and the number input box perfectly locked together.
        function syncSliders(baseId, updateFunction) {
            const slider = document.getElementById(baseId + '-slider');
            const numInput = document.getElementById(baseId);
            if (!slider || !numInput) return;

            slider.addEventListener('input', (e) => {
                numInput.value = e.target.value;
                updateFunction();
            });

            numInput.addEventListener('input', (e) => {
                slider.value = e.target.value;
                updateFunction();
            });
        }

        // --- 2. SIP CALCULATOR LOGIC ---
        let sipChartInstance = null;

        function updateSIP() {
            const p = parseFloat(document.getElementById('sip-amount').value) || 0;
            const r = parseFloat(document.getElementById('sip-rate').value) || 0;
            const t = parseFloat(document.getElementById('sip-years').value) || 0;

            const i = (r / 100) / 12;
            const n = t * 12;

            const invested = p * n;
            let futureValue = i === 0 ? invested : p * ((Math.pow(1 + i, n) - 1) / i) * (1 + i);
            const returns = futureValue - invested;

            document.getElementById('sip-invested').innerText = '₹' + fmt(invested);
            document.getElementById('sip-returns').innerText = '₹' + fmt(returns);
            document.getElementById('sip-total').innerText = '₹' + fmt(futureValue);

            if (sipChartInstance) {
                sipChartInstance.data.datasets[0].data = [invested, returns];
                sipChartInstance.update();
            } else {
                const ctx = document.getElementById('sipChart').getContext('2d');
                sipChartInstance = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Invested', 'Est. Returns'],
                        datasets: [{
                            data: [invested, returns],
                            backgroundColor: ['#1e293b', '#38bdf8'],
                            borderColor: '#0f172a',
                            borderWidth: 2,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: { legend: { display: false }, tooltip: { callbacks: { label: (c) => ' ₹' + fmt(c.parsed) } } },
                        cutout: '75%'
                    }
                });
            }
        }
        syncSliders('sip-amount', updateSIP);
        syncSliders('sip-rate', updateSIP);
        syncSliders('sip-years', updateSIP);
        updateSIP();

        // --- 3. P&L CALCULATOR LOGIC ---
        function updatePnL() {
            const buy = parseFloat(document.getElementById('pnl-buy').value) || 0;
            const sell = parseFloat(document.getElementById('pnl-sell').value) || 0;
            const qty = parseFloat(document.getElementById('pnl-qty').value) || 0;
            const fees = parseFloat(document.getElementById('pnl-fees').value) || 0;

            const totalCost = (buy * qty) + fees;
            const totalRevenue = (sell * qty) - fees; 
            const net = totalRevenue - totalCost;
            const roi = totalCost > 0 ? (net / totalCost) * 100 : 0;

            document.getElementById('pnl-capital').innerText = '₹' + fmt(totalCost);
            
            const netEl = document.getElementById('pnl-net');
            const labelEl = document.getElementById('pnl-status-label');
            
            if (net >= 0) {
                labelEl.innerText = "Net Profit";
                labelEl.style.color = "var(--profit)";
                netEl.className = "result-value val-profit";
                netEl.innerHTML = `+₹${fmt(net)} <span style="font-size: 1rem;">(${fmt(roi)}%)</span>`;
            } else {
                labelEl.innerText = "Net Loss";
                labelEl.style.color = "var(--loss)";
                netEl.className = "result-value val-loss";
                netEl.innerHTML = `-₹${fmt(Math.abs(net))} <span style="font-size: 1rem;">(${fmt(roi)}%)</span>`;
            }
        }
        syncSliders('pnl-buy', updatePnL);
        syncSliders('pnl-sell', updatePnL);
        syncSliders('pnl-qty', updatePnL);
        syncSliders('pnl-fees', updatePnL);
        updatePnL();

        // --- 4. POSITION SIZER LOGIC ---
        function updatePosition() {
            const cap = parseFloat(document.getElementById('pos-capital').value) || 0;
            const riskPct = parseFloat(document.getElementById('pos-risk').value) || 0;
            const entry = parseFloat(document.getElementById('pos-entry').value) || 0;
            const stop = parseFloat(document.getElementById('pos-stop').value) || 0;

            const riskAmount = cap * (riskPct / 100);
            document.getElementById('pos-risk-amount').innerText = '₹' + fmt(riskAmount);

            const riskPerShare = Math.abs(entry - stop);
            
            let qty = riskPerShare > 0 ? Math.floor(riskAmount / riskPerShare) : 0;
            if ((qty * entry) > cap) qty = Math.floor(cap / entry);

            document.getElementById('pos-qty').innerText = fmt(qty);
        }
        syncSliders('pos-capital', updatePosition);
        syncSliders('pos-risk', updatePosition);
        syncSliders('pos-entry', updatePosition);
        syncSliders('pos-stop', updatePosition);
        updatePosition();

        // --- 5. CAGR CALCULATOR LOGIC ---
        function updateCAGR() {
            const init = parseFloat(document.getElementById('cagr-initial').value) || 0;
            const finalVal = parseFloat(document.getElementById('cagr-final').value) || 0;
            const years = parseFloat(document.getElementById('cagr-years').value) || 0;

            let absReturn = init > 0 ? ((finalVal - init) / init) * 100 : 0;
            let cagr = (init > 0 && years > 0) ? (Math.pow((finalVal / init), (1 / years)) - 1) * 100 : 0;

            document.getElementById('cagr-absolute').innerText = fmt(absReturn) + '%';
            
            const resEl = document.getElementById('cagr-result');
            resEl.innerText = fmt(cagr) + '%';
            resEl.className = cagr >= 0 ? "result-value val-profit" : "result-value val-loss";
        }
        syncSliders('cagr-initial', updateCAGR);
        syncSliders('cagr-final', updateCAGR);
        syncSliders('cagr-years', updateCAGR);
        updateCAGR();

    </script>
</body>
</html>