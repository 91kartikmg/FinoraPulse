<script>
    // 1. Synchronize Top Ticker
  
    // 1. Synchronize Top Ticker
    function updateHeaderMarketWatch() {
        fetch('/api/market').then(res => res.json()).then(data => {
            document.querySelectorAll('#header-ticker [data-ticker]').forEach(el => {
                const ticker = el.getAttribute('data-ticker');
                if (data[ticker]) {
                    const priceEl = el.querySelector('.price-val'); 
                    const changeEl = el.querySelector('.change-val');
                    
                    const isIndian = ticker.includes('.NS') || ticker.includes('.BO') || ticker === 'INR=X' || ticker === '^NSEI';
                    const isEuro = ticker.includes('EUR');
                    const isPound = ticker.includes('GBP');
                    const isYen = ticker.includes('JPY');
                    
                    let sym = "$"; 
                    if (isIndian) sym = "₹";
                    if (isEuro) sym = "€";
                    if (isPound) sym = "£";
                    if (isYen) sym = "¥";
                    if (ticker.includes('^')) sym = "";
                    
                    const change = data[ticker].change; 
                    const isUp = change >= 0; 
                    
                    // FORCE COLORS VIA JAVASCRIPT
                    const textColor = isUp ? '#00FF41' : '#ff4d4d'; 

                    if (priceEl) { 
                        priceEl.innerText = sym + data[ticker].price.toFixed(2); 
                        priceEl.style.color = textColor; // Apply color to price
                    }
                    if (changeEl) { 
                        changeEl.innerText = (isUp ? '▲ ' : '▼ ') + Math.abs(change).toFixed(2) + '%'; 
                        changeEl.style.color = textColor; // Apply color to change %
                    }
                }
            });
        }).catch(err => console.log("Market sync paused..."));
    }
    
    updateHeaderMarketWatch(); 
    // Set to 15 minutes (900,000 milliseconds)
    setInterval(updateHeaderMarketWatch, 900000);

    // ... (Keep your Search Bar Auto-Suggest code the same below this) ...
    // 2. Search Bar Auto-Suggest
    const searchInput = document.getElementById('stockSearch');
    const suggestionsBox = document.getElementById('searchSuggestions');

    if(searchInput && suggestionsBox) {
        searchInput.addEventListener('input', async (e) => {
            const query = e.target.value;
            if (query.length < 2) { suggestionsBox.style.display = 'none'; return; }

            try {
                const res = await fetch(`/api/search-suggest?q=${query}`);
                const suggestions = await res.json();
                
                if (suggestions.length > 0) {
                    suggestionsBox.innerHTML = suggestions.map(s => `
                        <div class="suggestion-item" onclick="window.location.href='/predict?ticker=${s.symbol}'">
                            <strong>${s.symbol}</strong> - ${s.name}
                        </div>
                    `).join('');
                    suggestionsBox.style.display = 'block';
                } else {
                    suggestionsBox.style.display = 'none';
                }
            } catch (err) { console.error("Search error", err); }
        });

        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target)) suggestionsBox.style.display = 'none';
        });
    }
</script>