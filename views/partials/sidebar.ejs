    ];

    const globalBonds = [
        { category: "US Treasuries", id: "bnd-us", assets: [ { t: "^TNX", n: "US 10-Year Yield" }, { t: "^TYX", n: "US 30-Year Yield" }, { t: "^FVX", n: "US 5-Year Yield" } ] },
        { category: "Global Yields", id: "bnd-global", assets: [ { t: "IN10YT=RR", n: "India 10-Year" }, { t: "GB10YT=RR", n: "UK 10-Year" }, { t: "DE10YT=RR", n: "Germany 10-Year" } ] }
    ];

    // 3. INJECTION LOGIC
    function renderSidebarData() {
        const eqContainer = document.getElementById('equities');
        if(eqContainer) {
            eqContainer.innerHTML = globalEquities.map(region => `
                <div class="nested-acc-item">
                    <button class="nested-acc-btn" onclick="toggleNestedAcc('${region.id}', event)">${region.flag} ${region.country} <span class="arrow">▾</span></button>
                    <div id="${region.id}" class="nested-acc-content">${region.companies.map(c => `<a href="/predict?ticker=${c.t}">${c.n}</a>`).join('')}</div>
                </div>
            `).join('');
        }

        const cryptoContainer = document.getElementById('crypto');
        if(cryptoContainer) { cryptoContainer.innerHTML = globalCrypto.map(c => `<a href="/predict?ticker=${c.t}">${c.n}</a>`).join(''); }

        const forexContainer = document.getElementById('forex');
        if(forexContainer) {
            forexContainer.innerHTML = globalForex.map(group => `
                <div class="nested-acc-item">
                    <button class="nested-acc-btn" onclick="toggleNestedAcc('${group.id}', event)">${group.category} <span class="arrow">▾</span></button>
                    <div id="${group.id}" class="nested-acc-content">${group.pairs.map(p => `<a href="/predict?ticker=${p.t}">${p.n}</a>`).join('')}</div>
                </div>
            `).join('');
        }

        const commoditiesContainer = document.getElementById('commodities');
        if(commoditiesContainer) {
            commoditiesContainer.innerHTML = globalCommodities.map(group => `
                <div class="nested-acc-item">
                    <button class="nested-acc-btn" onclick="toggleNestedAcc('${group.id}', event)">${group.category} <span class="arrow">▾</span></button>
                    <div id="${group.id}" class="nested-acc-content">${group.assets.map(a => `<a href="/predict?ticker=${a.t}">${a.n}</a>`).join('')}</div>
