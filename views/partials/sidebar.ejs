        { country: "India", flag: "🇮🇳", id: "eq-india", companies: [ { t: "RELIANCE.NS", n: "Reliance" }, { t: "TCS.NS", n: "TCS" }, { t: "HDFCBANK.NS", n: "HDFC Bank" }, { t: "ICICIBANK.NS", n: "ICICI Bank" }, { t: "INFY.NS", n: "Infosys" }, { t: "SBIN.NS", n: "State Bank" }, { t: "BHARTIARTL.NS", n: "Bharti Airtel" }, { t: "ITC.NS", n: "ITC Ltd" }, { t: "HINDUNILVR.NS", n: "HUL" }, { t: "L&T.NS", n: "Larsen & Toubro" }, { t: "BAJFINANCE.NS", n: "Bajaj Finance" }, { t: "HCLTECH.NS", n: "HCL Tech" } ] },
        { country: "UK", flag: "🇬🇧", id: "eq-uk", companies: [ { t: "AZN.L", n: "AstraZeneca" }, { t: "SHEL.L", n: "Shell" }, { t: "HSBA.L", n: "HSBC" }, { t: "ULVR.L", n: "Unilever" }, { t: "BP.L", n: "BP" } ] },
        { country: "Canada", flag: "🇨🇦", id: "eq-can", companies: [ { t: "RY.TO", n: "Royal Bank of Canada" }, { t: "TD.TO", n: "TD Bank" }, { t: "SHOP.TO", n: "Shopify" } ] },
        { country: "Australia", flag: "🇦🇺", id: "eq-aus", companies: [ { t: "BHP.AX", n: "BHP Group" }, { t: "CBA.AX", n: "Commonwealth Bank" }, { t: "CSL.AX", n: "CSL Limited" } ] },
        { country: "Germany", flag: "🇩🇪", id: "eq-ger", companies: [ { t: "SAP.DE", n: "SAP" }, { t: "SIE.DE", n: "Siemens" }, { t: "ALV.DE", n: "Allianz" } ] },
        { country: "Japan", flag: "🇯🇵", id: "eq-jpn", companies: [ { t: "7203.T", n: "Toyota" }, { t: "6758.T", n: "Sony" }, { t: "8306.T", n: "MUFG" } ] },
