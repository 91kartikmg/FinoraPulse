    ];

    const globalCommodities = [
        { category: "Metals", id: "com-metals", assets: [ { t: "GC=F", n: "Gold" }, { t: "SI=F", n: "Silver" }, { t: "HG=F", n: "Copper" }, { t: "PL=F", n: "Platinum" } ] },
        { category: "Energy", id: "com-energy", assets: [ { t: "CL=F", n: "Crude Oil (WTI)" }, { t: "BZ=F", n: "Brent Crude" }, { t: "NG=F", n: "Natural Gas" } ] },
