<aside class="ticker-sidebar">
    <div class="sidebar-header">Global Market Watch</div>
    <div class="accordion-container">
        
        <div class="acc-item">
            <button class="acc-btn" onclick="toggleAcc('equities')">📈 Equities <span class="arrow">▾</span></button>
            <div id="equities" class="acc-content"></div>
        </div>

        <div class="acc-item">
            <button class="acc-btn" onclick="toggleAcc('crypto')">🪙 Crypto <span class="arrow">▾</span></button>
            <div id="crypto" class="acc-content"></div>
        </div>
        
        <div class="acc-item">
            <button class="acc-btn" onclick="toggleAcc('forex')">💱 Forex <span class="arrow">▾</span></button>
            <div id="forex" class="acc-content"></div>
        </div>
        
        <div class="acc-item">
            <button class="acc-btn" onclick="toggleAcc('commodities')">🛢️ Commodities <span class="arrow">▾</span></button>
            <div id="commodities" class="acc-content"></div>
        </div>

        <div class="acc-item">
            <button class="acc-btn" onclick="toggleAcc('indices')">📊 Indices <span class="arrow">▾</span></button>
            <div id="indices" class="acc-content"></div>
        </div>
        
        <div class="acc-item">
            <button class="acc-btn" onclick="toggleAcc('etfs')">🧺 ETFs <span class="arrow">▾</span></button>
            <div id="etfs" class="acc-content"></div>
        </div>
        
        <div class="acc-item">
            <button class="acc-btn" onclick="toggleAcc('bonds')">📜 Bonds & Rates <span class="arrow">▾</span></button>
            <div id="bonds" class="acc-content"></div>
        </div>

    </div>
</aside>

<script>
    // 1. ACCORDION CLICK LOGIC
    function toggleAcc(id) {
        const content = document.getElementById(id);
        const allContent = document.querySelectorAll('.acc-content');
        allContent.forEach(item => { if(item.id !== id) item.classList.remove('show'); });
        content.classList.toggle('show');
    }

    function toggleNestedAcc(id, event) {
        if(event) event.stopPropagation(); 
        const content = document.getElementById(id);
        const allContent = document.querySelectorAll('.nested-acc-content');
        allContent.forEach(item => { if(item.id !== id) item.classList.remove('nested-show'); });
        content.classList.toggle('nested-show');
    }

    // 2. MASSIVE DATA ARRAYS
