<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Sector Heatmap | StockPulse AI</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <link rel="stylesheet" href="/css/header.css" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/home.css" crossorigin="anonymous">
    <link rel="icon" type="image/x-icon" href="/favicon.png">
    
    <style>
        .nav-center { display: flex; align-items: center; gap: 40px; }
        .nav-search input {
            background: rgba(15, 23, 42, 0.6); border: 1px solid var(--border, #334155); color: white;
            padding: 8px 16px; border-radius: 8px; font-family: 'Inter', sans-serif; outline: none; width: 260px;
        }
        .nav-search input:focus { border-color: var(--accent, #38bdf8); }
        .btn { background: var(--accent); color: var(--bg-dark); border: none; padding: 8px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; text-decoration: none;}
        
        /* Heatmap Specific */
        .heatmap-container {
            background: var(--card-bg, #1e293b); padding: 25px; border-radius: 16px;
            border: 1px solid var(--border, #334155); margin-top: 10px; height: 75vh;
            display: flex; flex-direction: column;
        }
        
        /* Make main panel wider by overriding grid */
        .main-wrapper.wide { grid-template-columns: 280px 1fr; } 
    </style>
    <style>
        /* Active state for sidebar country selection */
        .ticker-list-item.active {
            background: var(--accent, #38bdf8);
            color: #0f172a; /* Dark text for contrast */
            font-weight: bold;
        }
        .ticker-list-item.active .symbol {
            color: #0f172a;
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>



    <div class="main-wrapper wide">
        <aside class="ticker-sidebar">
            <div class="sidebar-header">Global Markets</div>
            <div class="vertical-scroll-container" style="overflow-y: auto; max-height: 75vh; padding-bottom: 20px;">
                <div class="ticker-list-item <%= country === 'US' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=US'">
                    <span class="symbol">🇺🇸 United States</span>
                </div>
                <div class="ticker-list-item <%= country === 'CA' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=CA'">
                    <span class="symbol">🇨🇦 Canada</span>
                </div>
                <div class="ticker-list-item <%= country === 'MX' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=MX'">
                    <span class="symbol">🇲🇽 Mexico</span>
                </div>

                <div class="ticker-list-item <%= country === 'IN' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=IN'">
                    <span class="symbol">🇮🇳 India</span>
                </div>
                <div class="ticker-list-item <%= country === 'CN' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=CN'">
                    <span class="symbol">🇨🇳 China</span>
                </div>
                <div class="ticker-list-item <%= country === 'HK' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=HK'">
                    <span class="symbol">🇭🇰 Hong Kong</span>
                </div>
                <div class="ticker-list-item <%= country === 'JP' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=JP'">
                    <span class="symbol">🇯🇵 Japan</span>
                </div>
                <div class="ticker-list-item <%= country === 'KR' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=KR'">
                    <span class="symbol">🇰🇷 South Korea</span>
                </div>
                <div class="ticker-list-item <%= country === 'TW' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=TW'">
                    <span class="symbol">🇹🇼 Taiwan</span>
                </div>
                <div class="ticker-list-item <%= country === 'AU' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=AU'">
                    <span class="symbol">🇦🇺 Australia</span>
                </div>
                <div class="ticker-list-item <%= country === 'SG' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=SG'">
                    <span class="symbol">🇸🇬 Singapore</span>
                </div>
                <div class="ticker-list-item <%= country === 'ID' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=ID'">
                    <span class="symbol">🇮🇩 Indonesia</span>
                </div>

                <div class="ticker-list-item <%= country === 'GB' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=GB'">
                    <span class="symbol">🇬🇧 United Kingdom</span>
                </div>
                <div class="ticker-list-item <%= country === 'DE' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=DE'">
                    <span class="symbol">🇩🇪 Germany</span>
                </div>
                <div class="ticker-list-item <%= country === 'FR' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=FR'">
                    <span class="symbol">🇫🇷 France</span>
                </div>
                <div class="ticker-list-item <%= country === 'IT' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=IT'">
                    <span class="symbol">🇮🇹 Italy</span>
                </div>
                <div class="ticker-list-item <%= country === 'ES' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=ES'">
                    <span class="symbol">🇪🇸 Spain</span>
                </div>
                <div class="ticker-list-item <%= country === 'NL' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=NL'">
                    <span class="symbol">🇳🇱 Netherlands</span>
                </div>
                <div class="ticker-list-item <%= country === 'CH' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=CH'">
                    <span class="symbol">🇨🇭 Switzerland</span>
                </div>
                <div class="ticker-list-item <%= country === 'SE' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=SE'">
                    <span class="symbol">🇸🇪 Sweden</span>
                </div>
                <div class="ticker-list-item <%= country === 'PL' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=PL'">
                    <span class="symbol">🇵🇱 Poland</span>
                </div>

                <div class="ticker-list-item <%= country === 'SA' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=SA'">
                    <span class="symbol">🇸🇦 Saudi Arabia</span>
                </div>
                <div class="ticker-list-item <%= country === 'TR' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=TR'">
                    <span class="symbol">🇹🇷 Turkey</span>
                </div>
                <div class="ticker-list-item <%= country === 'ZA' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=ZA'">
                    <span class="symbol">🇿🇦 South Africa</span>
                </div>

                <div class="ticker-list-item <%= country === 'BR' ? 'active' : '' %>" onclick="window.location.href='/heatmap?country=BR'">
                    <span class="symbol">🇧🇷 Brazil</span>
                </div>
            </div>
        </aside>

        <main class="content-panel">
            <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 5px;">
                <div>
                   <h1 style="margin: 0; font-size: 2.2rem;">Live <span class="accent">
    <%= country === 'US' ? 'United States' : 
        country === 'IN' ? 'India' : 
        country === 'CN' ? 'China' : 
        country === 'GB' ? 'United Kingdom' : 
        country === 'JP' ? 'Japan' : country %>
</span> Heatmap</h1>
                    <p style="color: #94a3b8; margin-top: 5px;">Visualizing Market Cap (Size) & Daily Momentum (Color)</p>
                </div>
                
                <div id="status-text" style="color: #f59e0b; font-weight: bold; animation: pulse 1.5s infinite;">
                    Generating Map...
                </div>
            </div>

            <div class="heatmap-container">
                <div id="treemapChart" style="flex-grow: 1; width: 100%;"></div>
            </div>
        </main>
    </div>

    <script>
        async function loadHeatmap() {
            try {
                // Pass the EJS country variable to the API
                const response = await fetch('/api/heatmap-data?country=<%= country %>');
                const data = await response.json();

                if(data.error) {
                    document.getElementById('status-text').innerText = "Error loading data.";
                    return;
                }

                document.getElementById('status-text').innerText = "Live";
                document.getElementById('status-text').style.color = "#22c55e";
                document.getElementById('status-text').style.animation = "none";

                var options = {
                    series: data,
                    legend: { show: false },
                    chart: { 
                        type: 'treemap', 
                        height: '100%', 
                        background: 'transparent',
                        toolbar: { show: false }
                    },
                    dataLabels: {
                        enabled: true,
                        style: {
                            fontSize: '15px',
                            fontFamily: 'JetBrains Mono',
                            fontWeight: 'bold',
                            colors: ['#ffffff']
                        },
                        // This injects the Ticker Name and the % Change right into the box!
                        formatter: function(text, op) {
                            const change = op.w.config.series[op.seriesIndex].data[op.dataPointIndex].change;
                            const sign = change > 0 ? '+' : '';
                            return [text, sign + change + '%'];
                        }
                    },
                    plotOptions: {
                        treemap: {
                            enableShades: true,
                            shadeIntensity: 0.3,
                            useFillColorAsBg: true,
                            // Styles the outer sector containers
                            colorScale: {
                                ranges: [] // Overridden by our Python custom colors
                            }
                        }
                    },
                    stroke: { colors: ['#0f172a'], width: 2 },
                    tooltip: {
                        theme: 'dark',
                        y: { formatter: function(val) { return "Relative Size: " + val } }
                    }
                };

                var chart = new ApexCharts(document.querySelector("#treemapChart"), options);
                chart.render();

            } catch (err) {
                console.error(err);
                document.getElementById('status-text').innerText = "Connection Failed.";
            }
        }

        loadHeatmap();
    </script>
</body>
</html>