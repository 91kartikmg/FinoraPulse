<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin System | FinoraPulse</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@500;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/home.css" crossorigin="anonymous">
    
    <style>
        /* --- DASHBOARD STYLES (Fixed Layout) --- */
        .admin-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
            display: flex;
            flex-direction: column; /* This fixes the squished row issue */
            gap: 30px;
        }
        .admin-header { 
            display: flex; 
            justify-content: space-between; 
            align-items: flex-end; 
            border-bottom: 1px solid var(--border, #334155); 
            padding-bottom: 20px;
        }
        .metric-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); 
            gap: 20px; 
        }
        .metric-card { 
            background: var(--card-bg, #1e293b); 
            padding: 25px; 
            border-radius: 12px; 
            border: 1px solid var(--border, #334155); 
            border-left: 4px solid #a855f7; 
            display: flex; 
            flex-direction: column; 
            gap: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            transition: transform 0.2s;
        }
        .metric-card:hover { transform: translateY(-3px); }
        .metric-label { font-size: 0.85rem; color: var(--text-muted, #94a3b8); text-transform: uppercase; font-weight: bold; letter-spacing: 1px; }
        .metric-value { font-family: 'JetBrains Mono', monospace; font-size: 2.8rem; font-weight: 900; color: #f8fafc; line-height: 1; }
        
        .dashboard-panel { 
            background: #0d1117; 
            padding: 30px; 
            border-radius: 16px; 
            border: 1px solid var(--border, #334155); 
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        /* --- LOGIN STYLES --- */
        .login-wrapper { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #041027; font-family: 'Inter', sans-serif; }
        .login-box { background: #0f172a; padding: 40px; border-radius: 12px; border: 1px solid #334155; width: 100%; max-width: 400px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); text-align: center; }
        .login-box h2 { color: #a855f7; margin-top: 0; margin-bottom: 20px; }
        .input-group { margin-bottom: 20px; text-align: left; }
        .input-group label { display: block; color: #94a3b8; font-size: 0.85rem; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; }
        .input-group input { width: 100%; padding: 12px; background: #1e293b; border: 1px solid #334155; color: white; border-radius: 8px; outline: none; box-sizing: border-box; }
        .input-group input:focus { border-color: #a855f7; }
        .btn-admin { width: 100%; padding: 12px; background: #a855f7; color: white; font-weight: bold; border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s; }
        .btn-admin:hover { background: #9333ea; }
        .error-msg { color: #f43f5e; background: rgba(244, 63, 94, 0.1); padding: 10px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9rem; border: 1px solid rgba(244, 63, 94, 0.3); }
        
        .nav-btn { padding: 10px 20px; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; }
        .btn-return { background: #1e293b; color: white; border: 1px solid #334155; }
        .btn-return:hover { background: #334155; }
        .btn-logout { background: rgba(244, 63, 94, 0.1); color: #f43f5e; border: 1px solid rgba(244, 63, 94, 0.4); }
        .btn-logout:hover { background: rgba(244, 63, 94, 0.2); }
    </style>
</head>
<body style="margin: 0; background-color: var(--bg-dark, #041027);">

<% if (adminId) { %>
    <%- include('partials/header') %>

    <div class="admin-container">
        
        <div class="admin-header">
            <div>
                <h1 style="margin:0; font-size: 2.5rem; color: #f8fafc;">Command <span style="color: #a855f7;">Center</span></h1>
                <p style="color:var(--text-muted); margin: 5px 0 0 0; font-size: 1.1rem;">Live FinoraPulse Platform Analytics</p>
            </div>
            <div style="display: flex; gap: 12px;">
                <a href="/" class="nav-btn btn-return">← Return to App</a>
                <a href="/admin/logout" class="nav-btn btn-logout">Logout</a>
            </div>
        </div>

        <div class="metric-grid">
            <div class="metric-card">
                <span class="metric-label">Total Signups</span>
                <span class="metric-value" id="val-users">--</span>
            </div>
            <div class="metric-card" style="border-left-color: #38bdf8;">
                <span class="metric-label">Total Page Views</span>
                <span class="metric-value" id="val-views">--</span>
            </div>
            <div class="metric-card" style="border-left-color: #00FF9D;">
                <span class="metric-label">Server Uptime</span>
                <div style="display: flex; align-items: baseline; gap: 8px;">
                    <span class="metric-value" id="val-uptime">--</span>
                    <span style="color: #00FF9D; font-weight: bold; font-size: 1rem;">HRS</span>
                </div>
            </div>
            <div class="metric-card" style="border-left-color: #f59e0b;">
                <span class="metric-label">Active ML Models</span>
                <span class="metric-value" id="val-models">--</span>
            </div>
        </div>

        <div class="dashboard-panel">
            <h3 style="margin: 0 0 20px 0; color: #f8fafc; font-size: 1.4rem;">Platform Activity Overview</h3>
            <div style="position: relative; height: 400px; width: 100%;">
                <canvas id="activityChart"></canvas>
            </div>
        </div>
    </div>

    <script>
        let activityChartInstance = null;

        async function loadAdminAnalytics() {
            try {
                const response = await fetch('/api/admin/analytics');
                const data = await response.json();
                if (data.success) {
                    document.getElementById('val-users').innerText = data.totalSignups;
                    // UPDATED THIS LINE
                    document.getElementById('val-views').innerText = data.totalPageViews;
                    document.getElementById('val-uptime').innerText = data.serverUptime.split(' ')[0];
                    document.getElementById('val-models').innerText = data.activeModels;

                    // Initialize or update the chart with REAL data
                    initChart(data.chartData.labels, data.chartData.data);
                }
            } catch (err) {
                console.error("Error loading analytics:", err);
            }
        }

        function initChart(labels, data) {
            const ctx = document.getElementById('activityChart').getContext('2d');
            
            let gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, '#a855f7');   
            gradient.addColorStop(1, 'rgba(168, 85, 247, 0.1)');

            if (activityChartInstance) {
                activityChartInstance.destroy(); // Destroy old chart before drawing new one
            }

            activityChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels, // Real dates
                    datasets: [{
                        label: 'Page Views',
                        data: data, // Real numbers
                        backgroundColor: gradient,
                        borderRadius: 6,
                        borderWidth: 1,
                        borderColor: '#a855f7'
                    }]
                },
                options: {
                    responsive: true, 
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { display: false },
                        tooltip: { backgroundColor: '#1e293b', titleColor: '#a855f7', bodyFont: { size: 14 } }
                    },
                    scales: {
                        y: { 
                            grid: { color: 'rgba(51, 65, 85, 0.5)', drawBorder: false }, 
                            ticks: { color: '#94a3b8', font: { family: 'JetBrains Mono' }, stepSize: 1 } 
                        },
                        x: { 
                            grid: { display: false }, 
                            ticks: { color: '#94a3b8', font: { weight: 'bold' } } 
                        }
                    }
                }
            });
        }
        
        loadAdminAnalytics();
    </script>

<% } else { %>
    <div class="login-wrapper">
        <div class="login-box">
            <h2>System Gateway</h2>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-msg"><%= error %></div>
            <% } %>

            <form action="/admin/login" method="POST">
                <div class="input-group">
                    <label>Admin Email</label>
                    <input type="email" name="email" required placeholder="admin@finorapulse.com">
                </div>
                <div class="input-group">
                    <label>Master Password</label>
                    <input type="password" name="password" required placeholder="••••••••">
                </div>
                <button type="submit" class="btn-admin">Authorize Access</button>
            </form>
        </div>
    </div>
<% } %>

</body>
</html>