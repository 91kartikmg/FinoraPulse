<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StockPulse AI | Professional Terminal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/header.css" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/home.css" crossorigin="anonymous">
    <link rel="icon" type="image/x-icon" href="/favicon.png">

    <style>
        /* =========================================
           NEXT-LEVEL TERMINAL THEME
        ========================================= */
        :root {
            --term-bg: #05070a;
            --term-surface: #0a0e14;
            --term-border: #1e293b;
            --neon-green: #00FF41;
            --neon-cyan: #00E5FF;
            --neon-red: #ff3366;
            --text-main: #e2e8f0;
            --text-muted: #64748b;
        }

        body { background: var(--term-bg); color: var(--text-main); margin: 0; }

        /* CRT Screen Effect */
        .crt-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%);
            background-size: 100% 3px;
            pointer-events: none; z-index: 50; opacity: 0.6;
        }

        /* Premium Chart Container */
        .ai-chart-container {
            position: relative; 
            background: var(--term-surface); 
            border: 1px solid var(--term-border); 
            border-radius: 8px; 
            height: 400px; 
            overflow: hidden; 
            box-shadow: 0 20px 50px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(255,255,255,0.02);
        }

        /* Cyberpunk Corner Accents */
        .ai-chart-container::before, .ai-chart-container::after {
            content: ''; position: absolute; width: 20px; height: 20px; border: 2px solid var(--neon-cyan); z-index: 20; pointer-events: none;
        }
        .ai-chart-container::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
        .ai-chart-container::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }

        /* HUD Overlay styling */
        .chart-hud {
            position: absolute; top: 20px; left: 20px; 
            font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; 
            background: rgba(10, 14, 20, 0.85); 
            padding: 15px; border: 1px solid var(--term-border); 
            border-left: 3px solid var(--neon-cyan); border-radius: 4px; 
            backdrop-filter: blur(10px); z-index: 20; pointer-events: none;
        }

        .radar-scan {
            background: linear-gradient(90deg, transparent 0%, rgba(0, 255, 65, 0.02) 80%, rgba(0, 255, 65, 0.2) 100%);
            border-right: 1px solid var(--neon-green);
            animation: radar-sweep 5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }

        /* Animations */
        @keyframes radar-sweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        @keyframes pulse-glow {
            0% { box-shadow: 0 0 0 0 rgba(0, 255, 65, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(0, 255, 65, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 255, 65, 0); }
        }
        @keyframes tick-flash {
            0% { color: #fff; text-shadow: 0 0 15px #fff; transform: scale(1.05); }
            100% { color: var(--neon-green); text-shadow: none; transform: scale(1); }
        }
        .flash-active { animation: tick-flash 0.4s ease-out; display: inline-block; }

        /* Sidebar Lists */
        .terminal-row {
            display: flex; justify-content: space-between; padding: 12px; margin: 4px -10px; 
            border-radius: 4px; text-decoration: none; transition: all 0.2s ease;
            border: 1px solid transparent; background: rgba(255,255,255,0.01);
        }
        .terminal-row:hover {
            background: rgba(0, 255, 65, 0.05); border: 1px solid rgba(0, 255, 65, 0.3);
            transform: translateX(5px); box-shadow: -5px 0 15px rgba(0, 255, 65, 0.1);
        }
    </style>
    <style>
        .pinora{
            width: 100%;
            height: 200px;
            align-items: center;
            justify-content: center;
            display: flex;
        }
    </style>
</head>
<body>
    
    <%- include('partials/header') %>
    
    <div class="main-wrapper">
        <%- include('partials/sidebar') %>

        

        <main class="content-panel" style="padding: 30px;">
            <div class="pinora">
                <img src="/images/finorapulse-log.png" alt="FinoraPulse Logo" width="60%">
        </div>
            
            <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                <div>
                    
                    <div style="display: flex; align-items: center; gap: 10px; margin-top: 8px;">
                        <span style="height: 8px; width: 8px; background: var(--neon-green); border-radius: 50%; animation: pulse-glow 2s infinite;"></span>
                        <span style="font-size: 0.75rem; color: var(--text-muted); font-family: 'JetBrains Mono'; letter-spacing: 1px;">
                            NEURAL_NET: <span style="color: var(--text-main);">ONLINE</span> // FEED: <span style="color: var(--neon-cyan);">REALTIME</span>
                        </span>
                    </div>
                </div>

                <div style="display: flex; gap: 20px; background: var(--term-surface); padding: 15px 25px; border-radius: 6px; border: 1px solid var(--term-border);">
                    <div style="text-align: right; border-right: 1px solid #334155; padding-right: 20px;">
                        <div style="color: var(--text-muted); font-size: 0.65rem; letter-spacing: 1px;">AI_SENTIMENT</div>
                        <div style="color: var(--neon-green); font-family: 'JetBrains Mono'; font-weight: bold; font-size: 1.1rem;">STRONG_BUY</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="color: var(--text-muted); font-size: 0.65rem; letter-spacing: 1px;">CONFIDENCE</div>
                        <div style="color: #fff; font-family: 'JetBrains Mono'; font-weight: bold; font-size: 1.1rem;">98.2%</div>
                    </div>
                </div>
            </header>

            <div class="ai-chart-container" id="chart-wrapper">
                <div class="crt-overlay"></div>
                <div class="radar-scan" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10;"></div>
                
               
                <canvas id="tv-chart" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 2; cursor: crosshair;"></canvas>

                <div class="chart-hud">
                    <div style="color: var(--neon-cyan); font-weight: bold; margin-bottom: 8px; border-bottom: 1px solid #1e293b; padding-bottom: 5px;">MARKET_PULSE_DETECTOR</div>
                    <div style="margin-bottom: 3px;">TICK: <span id="live-tick-price" style="color:#fff; font-size: 1.1rem;">AWAITING_DATA...</span></div>
                    <div>TREND: <span style="color:var(--neon-green)">ACCELERATING_UP</span></div>
                </div>
            </div>
        </main>

        <aside class="side-panel right">
            <%- include('partials/global') %>
        </aside>
        
    </div>

    <script>
    async function updateMarketData() {
        try {
            const response = await fetch('/api/market');
            const data = await response.json();
            const container = document.getElementById('dynamic-cards');
            if(!container) return; // Prevent errors if partial isn't loaded
            
            const createRow = (item) => `
                <a href="/predict?ticker=${item.original_ticker}" class="terminal-row">
                    <span style="font-weight: bold; color: #fff; font-family: 'JetBrains Mono';">${item.symbol}</span>
                    <span style="color: ${item.change >= 0 ? 'var(--neon-green)' : 'var(--neon-red)'}; font-family: 'JetBrains Mono'; text-shadow: 0 0 10px ${item.change >= 0 ? 'rgba(0,255,65,0.3)' : 'rgba(255,51,102,0.3)'}">
                        ${item.change >= 0 ? '+' : ''}${item.change}%
                    </span>
                </a>
            `;

            container.innerHTML = `
                <div style="background: var(--term-surface); border: 1px solid var(--term-border); border-radius: 8px; padding: 20px; margin-bottom: 15px;">
                    <div style="color: var(--text-muted); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px; border-bottom: 1px solid var(--term-border); padding-bottom: 10px;">
                        <span style="color: var(--neon-green);">●</span> Bullish_Equities.exe
                    </div>
                    ${data.stocks.map(createRow).join('')}
                </div>

                <div style="background: var(--term-surface); border: 1px solid var(--term-border); border-radius: 8px; padding: 20px; margin-bottom: 15px;">
                    <div style="color: var(--text-muted); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px; border-bottom: 1px solid var(--term-border); padding-bottom: 10px;">
                        <span style="color: var(--neon-cyan);">●</span> Digital_Assets.bin
                    </div>
                    ${data.crypto.slice(0, 2).map(createRow).join('')}
                    ${data.forex.slice(0, 1).map(createRow).join('')}
                </div>
            `;
        } catch (e) { 
            console.error("Terminal Data Linkage Failed:", e); 
        }
    }
    setInterval(updateMarketData, 30000);
    updateMarketData();
    </script>

    <script>
        const container = document.getElementById("chart-wrapper");
        const canvas = document.getElementById("tv-chart");
        const ctx = canvas.getContext("2d");
        
        let mouseX = -1;
        let mouseY = -1;

        function resize() {
            // High DPI Canvas resolution
            const rect = container.getBoundingClientRect();
            canvas.width = rect.width * window.devicePixelRatio;
            canvas.height = rect.height * window.devicePixelRatio;
            ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
            canvas.style.width = `${rect.width}px`;
            canvas.style.height = `${rect.height}px`;
        }
        window.addEventListener("resize", resize);
        resize();

        // Track Mouse for Crosshair
        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            mouseX = e.clientX - rect.left;
            mouseY = e.clientY - rect.top;
        });
        canvas.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

        // Data Simulation
        let historyData = [];
        let prediction = [];
        let price = 150;

        for(let i=0; i<80; i++) { price += (Math.random() - 0.45) * 4; historyData.push(price); }
        let last = historyData[historyData.length-1];
        for(let i=0; i<40; i++) { last += (Math.random() - 0.40) * 5; prediction.push(last); }

        function draw() {
            const width = canvas.width / window.devicePixelRatio;
            const height = canvas.height / window.devicePixelRatio;
            
            ctx.clearRect(0, 0, width, height);

            const paddingX = 40, paddingRight = 70, paddingY = 40;
            const all = [...historyData, ...prediction];
            const min = Math.min(...all) - 2; 
            const max = Math.max(...all) + 2; 

            function y(v) { return height - paddingY - ((v - min) / (max - min)) * (height - paddingY * 2); }
            const step = (width - paddingX - paddingRight) / (historyData.length + prediction.length - 1);

            // 1. Grid & Price Labels
            ctx.fillStyle = "#64748b";
            ctx.font = "11px 'JetBrains Mono', monospace";
            ctx.textBaseline = "middle";
            ctx.textAlign = "left";

            for(let i=0; i<=5; i++) {
                let gy = paddingY + i * (height - paddingY * 2) / 5;
                let priceVal = max - (i / 5) * (max - min);

                ctx.beginPath();
                ctx.strokeStyle = "rgba(255, 255, 255, 0.04)";
                ctx.lineWidth = 1;
                ctx.moveTo(paddingX, gy); ctx.lineTo(width - paddingRight, gy);
                ctx.stroke();

                ctx.fillText("$" + priceVal.toFixed(2), width - paddingRight + 15, gy);
            }

            // 2. Time Grid
            ctx.textAlign = "center";
            ctx.textBaseline = "top";
            let now = new Date();
            for(let i=0; i<=6; i++) {
                let gx = paddingX + i * (width - paddingX - paddingRight) / 6;
                ctx.beginPath();
                ctx.strokeStyle = "rgba(255, 255, 255, 0.02)";
                ctx.moveTo(gx, paddingY); ctx.lineTo(gx, height - paddingY);
                ctx.stroke();

                let timeStr = new Date(now.getTime() - (4 - i) * 60000).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                ctx.fillText(timeStr, gx, height - paddingY + 15);
            }

            // 3. Historical Gradient
            let gradHist = ctx.createLinearGradient(0, paddingY, 0, height - paddingY);
            gradHist.addColorStop(0, "rgba(0, 229, 255, 0.2)");
            gradHist.addColorStop(1, "rgba(0, 229, 255, 0.0)");

            ctx.beginPath();
            ctx.moveTo(paddingX, height - paddingY);
            historyData.forEach((v, i) => ctx.lineTo(paddingX + i * step, y(v)));
            let endHistX = paddingX + (historyData.length - 1) * step;
            ctx.lineTo(endHistX, height - paddingY);
            ctx.fillStyle = gradHist; ctx.fill();

            // Historical Line
            ctx.lineWidth = 2.5;
            ctx.strokeStyle = "#00E5FF";
            ctx.shadowColor = "rgba(0, 229, 255, 0.6)";
            ctx.shadowBlur = 8;
            ctx.beginPath();
            historyData.forEach((v, i) => {
                let px = paddingX + i * step, py = y(v);
                if(i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
            });
            ctx.stroke();
            ctx.shadowBlur = 0;

            // 4. Prediction Gradient
            let gradPred = ctx.createLinearGradient(0, paddingY, 0, height - paddingY);
            gradPred.addColorStop(0, "rgba(0, 255, 65, 0.15)");
            gradPred.addColorStop(1, "rgba(0, 255, 65, 0.0)");

            ctx.beginPath();
            ctx.moveTo(endHistX, height - paddingY);
            let startY = y(historyData[historyData.length - 1]);
            ctx.lineTo(endHistX, startY);
            prediction.forEach((v, i) => ctx.lineTo(paddingX + (i + historyData.length - 1) * step, y(v)));
            ctx.lineTo(paddingX + (historyData.length + prediction.length - 2) * step, height - paddingY);
            ctx.fillStyle = gradPred; ctx.fill();

            // Prediction Line
            ctx.strokeStyle = "#00FF41";
            ctx.setLineDash([4, 4]);
            ctx.beginPath();
            prediction.forEach((v, i) => {
                let px = paddingX + (i + historyData.length - 1) * step, py = y(v);
                if(i === 0) ctx.moveTo(endHistX, startY); else ctx.lineTo(px, py);
            });
            ctx.stroke();
            ctx.setLineDash([]);

            // Divider Line (Present Time)
            ctx.beginPath();
            ctx.strokeStyle = "rgba(255, 255, 255, 0.3)";
            ctx.setLineDash([2, 2]);
            ctx.moveTo(endHistX, paddingY);
            ctx.lineTo(endHistX, height - paddingY);
            ctx.stroke();
            ctx.setLineDash([]);
            
            ctx.fillStyle = "#fff";
            ctx.font = "10px monospace";
            ctx.fillText("NOW", endHistX, paddingY - 15);

            // 5. Live Glowing Node
            ctx.beginPath(); ctx.arc(endHistX, startY, 5, 0, Math.PI * 2);
            ctx.fillStyle = "#00FF41"; ctx.shadowColor = "#00FF41"; ctx.shadowBlur = 15; ctx.fill();
            ctx.beginPath(); ctx.arc(endHistX, startY, 2, 0, Math.PI * 2);
            ctx.fillStyle = "#fff"; ctx.shadowBlur = 0; ctx.fill();

            // 6. Interactive Crosshair (Hover Effect)
            if (mouseX > paddingX && mouseX < width - paddingRight && mouseY > paddingY && mouseY < height - paddingY) {
                ctx.beginPath();
                ctx.strokeStyle = "rgba(255, 255, 255, 0.5)";
                ctx.lineWidth = 1;
                // Vertical
                ctx.moveTo(mouseX, paddingY); ctx.lineTo(mouseX, height - paddingY);
                // Horizontal
                ctx.moveTo(paddingX, mouseY); ctx.lineTo(width - paddingRight, mouseY);
                ctx.stroke();

                // Target Node on line
                let exactPrice = min + ((height - paddingY - mouseY) / (height - paddingY * 2)) * (max - min);
                
                // Crosshair Labels
                ctx.fillStyle = "#fff";
                ctx.fillRect(width - paddingRight, mouseY - 10, 60, 20);
                ctx.fillStyle = "#000";
                ctx.fillText("$" + exactPrice.toFixed(2), width - paddingRight + 30, mouseY);
            }

            requestAnimationFrame(draw);
        }
        draw();

        // AI Tick Simulation
        const tickEl = document.getElementById("live-tick-price");
        setInterval(() => {
            historyData.push(prediction.shift());
            let last = historyData[historyData.length - 1];
            let next = last + (Math.random() - 0.40) * 4;
            prediction.push(next);
            historyData.shift();

            // Update & Flash
            tickEl.innerText = "$" + next.toFixed(2);
            tickEl.classList.remove("flash-active");
            void tickEl.offsetWidth; // Trigger reflow
            tickEl.classList.add("flash-active");
        }, 1500);
    </script>

    <script>
        async function loadLiquidityMatrix() {
            try {
                const response = await fetch('/api/fii-dii');
                const data = await response.json();
                if(data.error) return;

                const fmt = (num) => new Intl.NumberFormat('en-IN').format(Math.abs(num));
                
                const fiiVal = document.getElementById('fii-val');
                const diiVal = document.getElementById('dii-val');
                const netVal = document.getElementById('net-val');
                const statusBox = document.getElementById('liquidity-status');

                if(fiiVal) {
                    fiiVal.innerText = (data.fii >= 0 ? "+" : "-") + fmt(data.fii) + " Cr";
                    fiiVal.style.color = data.fii >= 0 ? "var(--neon-green)" : "var(--neon-red)";
                }
                if(statusBox) {
                    statusBox.innerText = data.status;
                    statusBox.style.color = data.status.includes("Bullish") ? "var(--neon-green)" : "var(--neon-red)";
                }
                // ... Additional DOM logic left intact for your global partial ...
            } catch (err) { console.error("Matrix Error:", err); }
        }
        loadLiquidityMatrix();
    </script>
</body>
</html>